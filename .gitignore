.env
.env.*
!.env.example

# --- logs and runtime noise
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
srv.log
srv.err
api.log
api.err
vite.log
vite.err

# --- editor and tooling
.vscode/
.idea/
*.swp
*.swo
.history/

# --- OS
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

