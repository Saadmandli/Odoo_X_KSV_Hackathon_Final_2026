# Copy to .env and fill in.
#
# Note the variable name: CARPOOL_DATABASE_URL, not DATABASE_URL. Real
# environment variables override .env files in both Prisma and dotenv, so a
# project-specific name avoids clashing with anything already set on the machine.
CARPOOL_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/carpool_pern?schema=public"

# Signs the auth tokens. Use a long random string in production.
JWT_SECRET="change-me"

PORT=4000
CORS_ORIGINS="http://localhost:5173"
NODE_ENV=development

# Optional. Without these, card and UPI payments complete in sandbox mode.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
